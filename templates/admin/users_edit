{% extends "base.html" %}

{% block title %}Edit User: {{ user.username }} - {{ panel_name }}{% endblock %}

{% block header_title %}Edit User: {{ user.username }}{% endblock %}

{% block breadcrumbs %}
<div class="breadcrumb">
    <a href="{{ url_for('dashboard') }}" class="breadcrumb-item">Dashboard</a>
    <span class="breadcrumb-separator"><i class="fas fa-chevron-right"></i></span>
    <a href="{{ url_for('admin_dashboard') }}" class="breadcrumb-item">Admin</a>
    <span class="breadcrumb-separator"><i class="fas fa-chevron-right"></i></span>
    <a href="{{ url_for('admin_users') }}" class="breadcrumb-item">Users</a>
    <span class="breadcrumb-separator"><i class="fas fa-chevron-right"></i></span>
    <span class="breadcrumb-item active">{{ user.username }}</span>
</div>
{% endblock %}

{% block content %}
<!-- User Header -->
<div class="card" style="margin-bottom: 1.5rem;">
    <div style="display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <div class="user-avatar" style="width: 64px; height: 64px;">
                {% if user.profile_picture %}
                <img src="{{ user.profile_picture }}" alt="{{ user.username }}">
                {% else %}
                <span style="font-size: 1.5rem;">{{ user.username[:1].upper() }}</span>
                {% endif %}
            </div>
            <div>
                <h2 style="font-size: 1.5rem; margin-bottom: 0.25rem;">{{ user.username }}</h2>
                <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
                    {% if user.is_main_admin %}
                    <span class="badge badge-danger">Main Admin</span>
                    {% elif user.is_admin %}
                    <span class="badge badge-warning">Administrator</span>
                    {% else %}
                    <span class="badge badge-success">User</span>
                    {% endif %}
                    <span class="badge badge-info">{{ vps_count }} VPS</span>
                    <span class="badge" style="background-color: var(--bg-tertiary);">
                        <i class="fas fa-calendar"></i> Joined {{ user.created_at|relative_time }}
                    </span>
                </div>
            </div>
        </div>
        
        <div style="margin-left: auto; display: flex; gap: 0.75rem; flex-wrap: wrap;">
            <a href="{{ url_for('admin_user_detail', user_id=user.id) }}" class="btn btn-outline">
                <i class="fas fa-eye"></i>
                <span>View Details</span>
            </a>
            {% if not user.is_main_admin %}
            <button class="btn btn-danger" onclick="deleteUser()">
                <i class="fas fa-trash"></i>
                <span>Delete User</span>
            </button>
            {% endif %}
        </div>
    </div>
</div>

<!-- Edit Form -->
<div class="grid grid-2">
    <!-- Account Information -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-user"></i>
                Account Information
            </h3>
        </div>
        
        <table style="width: 100%;">
            <tr>
                <td style="padding: 0.75rem 0; color: var(--text-muted); width: 40%;">User ID</td>
                <td style="padding: 0.75rem 0; font-weight: 600;">{{ user.id }}</td>
            </tr>
            <tr>
                <td style="padding: 0.75rem 0; color: var(--text-muted);">Username</td>
                <td style="padding: 0.75rem 0; font-weight: 600;">{{ user.username }}</td>
            </tr>
            <tr>
                <td style="padding: 0.75rem 0; color: var(--text-muted);">Email</td>
                <td style="padding: 0.75rem 0; font-weight: 600;">{{ user.email }}</td>
            </tr>
            <tr>
                <td style="padding: 0.75rem 0; color: var(--text-muted);">Created</td>
                <td style="padding: 0.75rem 0;">{{ user.created_at|relative_time }}</td>
            </tr>
            <tr>
                <td style="padding: 0.75rem 0; color: var(--text-muted);">Last Login</td>
                <td style="padding: 0.75rem 0;">{{ user.last_login|relative_time if user.last_login else 'Never' }}</td>
            </tr>
            <tr>
                <td style="padding: 0.75rem 0; color: var(--text-muted);">Last Active</td>
                <td style="padding: 0.75rem 0;">{{ user.last_active|relative_time if user.last_active else 'Never' }}</td>
            </tr>
        </table>
    </div>

    <!-- Resource Usage -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-chart-bar"></i>
                Resource Usage
            </h3>
        </div>
        
        <div style="margin-bottom: 1.5rem;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                <span>VPS Count</span>
                <span style="font-weight: 600;">{{ vps_count }}</span>
            </div>
            <div class="progress">
                <div class="progress-bar success" style="width: {{ (vps_count / 10 * 100)|round }}%;"></div>
            </div>
            <small style="color: var(--text-muted);">Maximum: 10 VPS (configurable)</small>
        </div>

        <div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                <span>Port Forwarding</span>
                <span style="font-weight: 600;">{{ port_allocation.used_ports or 0 }} / {{ port_allocation.allocated_ports or 0 }}</span>
            </div>
            <div class="progress">
                {% set port_percent = ((port_allocation.used_ports or 0) / (port_allocation.allocated_ports or 1) * 100)|round %}
                <div class="progress-bar {% if port_percent > 80 %}danger{% elif port_percent > 60 %}warning{% else %}success{% endif %}" 
                     style="width: {{ port_percent }}%;"></div>
            </div>
            <small style="color: var(--text-muted);">Ports used / allocated</small>
        </div>
    </div>
</div>

<!-- Edit Settings -->
<div class="card" style="margin-top: 1.5rem;">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-cog"></i>
            Edit User Settings
        </h3>
    </div>

    <form id="editUserForm">
        <div class="grid grid-2">
            <!-- Permissions -->
            <div style="padding: 1rem; background-color: var(--bg-secondary); border-radius: var(--border-radius-sm); border: 1px solid var(--border-color);">
                <h4 style="margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
                    <i class="fas fa-user-shield"></i>
                    Permissions
                </h4>
                
                {% if not user.is_main_admin %}
                <div class="form-group">
                    <label class="form-label" style="display: flex; align-items: center; gap: 0.5rem;">
                        <input type="checkbox" id="is_admin" {% if user.is_admin %}checked{% endif %} style="width: auto; margin: 0;">
                        Administrator Privileges
                    </label>
                    <small style="color: var(--text-muted); display: block; margin-top: 0.25rem;">
                        Grants full access to admin panel and system management
                    </small>
                </div>
                {% else %}
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i>
                    <span>This is the main administrator account. Permissions cannot be modified.</span>
                </div>
                {% endif %}
            </div>

            <!-- Quotas -->
            <div style="padding: 1rem; background-color: var(--bg-secondary); border-radius: var(--border-radius-sm); border: 1px solid var(--border-color);">
                <h4 style="margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
                    <i class="fas fa-sliders-h"></i>
                    Quotas
                </h4>
                
                <div class="form-group">
                    <label class="form-label">Port Forwarding Quota</label>
                    <input type="number" id="port_quota" class="form-control" value="{{ port_allocation.allocated_ports or 0 }}" min="0" max="1000">
                    <small style="color: var(--text-muted);">
                        Currently using {{ port_allocation.used_ports or 0 }} ports
                    </small>
                </div>
            </div>
        </div>

        <!-- Password Reset -->
        <div style="margin-top: 1.5rem; padding: 1rem; background-color: var(--bg-secondary); border-radius: var(--border-radius-sm); border: 1px solid var(--border-color);">
            <h4 style="margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
                <i class="fas fa-key"></i>
                Password Reset (Optional)
            </h4>
            
            <div class="grid grid-2">
                <div class="form-group">
                    <label class="form-label">New Password</label>
                    <div style="position: relative;">
                        <input type="password" id="new_password" class="form-control" placeholder="Leave blank to keep current" minlength="8" autocomplete="new-password">
                        <button type="button" class="btn btn-icon" onclick="togglePassword('new_password', 'passwordToggleIcon')" style="position: absolute; right: 0.5rem; top: 50%; transform: translateY(-50%);">
                            <i class="fas fa-eye" id="passwordToggleIcon"></i>
                        </button>
                    </div>
                    <small style="color: var(--text-muted);">Minimum 8 characters if changing</small>
                </div>

                <div class="form-group">
                    <label class="form-label">Confirm New Password</label>
                    <input type="password" id="confirm_password" class="form-control" placeholder="Confirm new password" minlength="8" autocomplete="new-password">
                    <small style="color: var(--text-muted);">Must match new password</small>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div style="display: flex; gap: 1rem; justify-content: flex-end; margin-top: 1.5rem;">
            <a href="{{ url_for('admin_users') }}" class="btn btn-outline">
                <i class="fas fa-times"></i> Cancel
            </a>
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> Save Changes
            </button>
        </div>
    </form>
</div>
{% endblock %}

{% block extra_js %}
<script>
    // Toggle password visibility
    function togglePassword(inputId, iconId) {
        const passwordInput = document.getElementById(inputId);
        const icon = document.getElementById(iconId);
        
        if (passwordInput.type === 'password') {
            passwordInput.type = 'text';
            icon.className = 'fas fa-eye-slash';
        } else {
            passwordInput.type = 'password';
            icon.className = 'fas fa-eye';
        }
    }

    // Form submission
    document.getElementById('editUserForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        const is_admin = document.getElementById('is_admin')?.checked || {{ 'true' if user.is_main_admin else 'false' }};
        const port_quota = parseInt(document.getElementById('port_quota').value);
        const new_password = document.getElementById('new_password').value.trim();
        const confirm_password = document.getElementById('confirm_password').value.trim();

        // Validation
        if (port_quota < 0) {
            showToast('Port quota cannot be negative', 'warning');
            return;
        }

        if (new_password && new_password.length < 8) {
            showToast('New password must be at least 8 characters', 'warning');
            return;
        }

        if (new_password && new_password !== confirm_password) {
            showToast('Passwords do not match', 'warning');
            return;
        }

        showLoading();

        try {
            // Update user settings
            const response = await fetch('/admin/users/{{ user.id }}/edit', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    is_admin: is_admin,
                    port_quota: port_quota
                })
            });

            // Debug: Log response details
            console.log('Response status:', response.status);
            console.log('Response headers:', response.headers.get('content-type'));
            
            // Check if response is actually JSON
            const contentType = response.headers.get('content-type');
            if (!contentType || !contentType.includes('application/json')) {
                const text = await response.text();
                console.error('Expected JSON but got:', text.substring(0, 500));
                throw new Error('Server returned HTML instead of JSON. Check console for details.');
            }

            const result = await response.json();

            if (!result.success) {
                throw new Error(result.error || 'Failed to update user');
            }

            // Update password if provided
            if (new_password) {
                const formData = new FormData();
                formData.append('password', new_password);

                const passResponse = await fetch('/admin/users/{{ user.id }}/reset-password', {
                    method: 'POST',
                    body: formData
                });

                const passResult = await passResponse.json();

                if (!passResult.success) {
                    throw new Error(passResult.error || 'Failed to reset password');
                }
            }

            showToast('User updated successfully!', 'success');
            setTimeout(() => {
                window.location.href = "{{ url_for('admin_users') }}";
            }, 2000);

        } catch (error) {
            console.error('Update user error:', error);
            showToast(error.message || 'Failed to update user', 'danger');
        } finally {
            hideLoading();
        }
    });

    // Delete user
    async function deleteUser() {
        if (!confirm('Are you sure you want to delete user "{{ user.username }}"?\n\nThis will permanently delete:\n- User account\n- All VPS owned by this user\n- All port forwards\n- All data associated with this user\n\nThis action cannot be undone!')) {
            return;
        }

        showLoading();

        try {
            const response = await fetch('/admin/users/{{ user.id }}/delete', {
                method: 'POST'
            });

            const result = await response.json();

            if (result.success) {
                showToast('User deleted successfully', 'success');
                setTimeout(() => {
                    window.location.href = "{{ url_for('admin_users') }}";
                }, 2000);
            } else {
                showToast(result.error || 'Failed to delete user', 'danger');
            }
        } catch (error) {
            console.error('Delete user error:', error);
            showToast('Network error: ' + error.message, 'danger');
        } finally {
            hideLoading();
        }
    }
</script>
{% endblock %}
