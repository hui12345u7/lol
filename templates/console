<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ panel_name }} · VPS Console</title>
    <!-- Bootstrap 5 Darkly theme (cosmo variation) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Xterm.js for terminal emulation -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/xterm@5.3.0/css/xterm.min.css" />
    <!-- Socket.IO client -->
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <style>
        :root {
            --bg-dark: #1a1d21;
            --bg-darker: #0f1114;
            --border-color: #2b2f36;
            --accent-cyan: #0dcaf0;
            --accent-green: #198754;
            --text-muted: #9ca3af;
        }
        body {
            background-color: var(--bg-darker);
            color: #e9ecef;
            font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Courier New', monospace;
            height: 100vh;
            overflow: hidden;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
        }
        /* top bar */
        .console-topbar {
            background-color: #21252b;
            border-bottom: 1px solid var(--border-color);
            padding: 0.5rem 1rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
            user-select: none;
        }
        .vps-badge {
            background: #2c313a;
            padding: 0.35rem 1rem;
            border-radius: 30px;
            font-size: 0.9rem;
            border-left: 4px solid var(--accent-cyan);
            font-weight: 500;
        }
        .vps-badge i {
            color: var(--accent-cyan);
            margin-right: 6px;
        }
        .conn-status {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            background: #1e2228;
            padding: 0.2rem 1rem;
            border-radius: 30px;
        }
        .status-led {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #6c757d;
            transition: background 0.2s;
        }
        .status-led.connected {
            background: #28a745;
            box-shadow: 0 0 8px #28a74580;
        }
        .status-led.disconnected {
            background: #dc3545;
        }
        .status-led.connecting {
            background: #ffc107;
        }
        .control-buttons .btn {
            background: #2c313a;
            border: none;
            color: #dee2e6;
            margin-left: 0.3rem;
            border-radius: 6px;
            padding: 0.25rem 0.9rem;
            font-size: 0.85rem;
            transition: all 0.1s;
        }
        .control-buttons .btn:hover {
            background: #3a404b;
            color: white;
        }
        .control-buttons .btn-exit {
            background: #a4262c;
        }
        .control-buttons .btn-exit:hover {
            background: #c53030;
        }
        /* main terminal area */
        #terminal-container {
            flex: 1;
            background: #0c0e12;
            padding: 8px 0 0 8px;
            overflow: hidden;
        }
        .xterm {
            height: 100%;
            padding: 4px;
        }
        .xterm-viewport {
            overflow-y: auto !important;
            scrollbar-width: thin;
            scrollbar-color: #3b3f4a #1e2127;
        }
        .xterm-viewport::-webkit-scrollbar {
            width: 8px;
        }
        .xterm-viewport::-webkit-scrollbar-track {
            background: #1e2127;
        }
        .xterm-viewport::-webkit-scrollbar-thumb {
            background: #3b3f4a;
            border-radius: 4px;
        }
        /* bottom helper bar */
        .console-footer {
            background: #1b1f25;
            border-top: 1px solid var(--border-color);
            padding: 0.4rem 1rem;
            font-size: 0.8rem;
            color: var(--text-muted);
            display: flex;
            gap: 2rem;
            flex-wrap: wrap;
            flex-shrink: 0;
        }
        .footer-hint i {
            width: 18px;
            color: #6c8a9e;
        }
        /* login overlay (ssh connect) */
        .ssh-login-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(10, 12, 16, 0.92);
            backdrop-filter: blur(3px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2000;
            transition: opacity 0.2s;
        }
        .ssh-login-card {
            background: #232731;
            border-radius: 20px;
            width: 400px;
            padding: 2rem;
            border: 1px solid #3a4050;
            box-shadow: 0 25px 50px -12px black;
        }
        .ssh-login-card h3 {
            font-weight: 400;
            margin-bottom: 1.5rem;
            color: #b2c9e8;
        }
        .form-control, .input-group-text {
            background-color: #1a1e27;
            border: 1px solid #333a47;
            color: white;
        }
        .form-control:focus {
            background-color: #222834;
            border-color: var(--accent-cyan);
            box-shadow: 0 0 0 0.2rem #0dcaf040;
        }
        .btn-connect {
            background: #0d6efd;
            border: none;
            width: 100%;
            padding: 0.7rem;
            font-weight: 500;
        }
        .btn-connect:hover {
            background: #0b5ed7;
        }
        .small-note {
            font-size: 0.8rem;
            color: #8f9bb3;
            margin-top: 1rem;
            text-align: center;
        }
        /* hidden by default */
        .d-none {
            display: none !important;
        }
    </style>
</head>
<body>

    <!-- SSH connection overlay (visible until connected) -->
    <div id="sshOverlay" class="ssh-login-overlay">
        <div class="ssh-login-card">
            <h3><i class="fa-solid fa-terminal me-2" style="color: #0dcaf0;"></i>Connect to VPS</h3>
            <div class="mb-3">
                <label class="form-label">Host / IP</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa-solid fa-network-wired"></i></span>
                    <input type="text" class="form-control" id="sshHost" placeholder="e.g. 192.168.1.100 or your.vps.com" value="{{ vps_ip or '' }}">
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Port</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa-regular fa-plug"></i></span>
                    <input type="number" class="form-control" id="sshPort" value="22" min="1" max="65535">
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Username</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa-regular fa-user"></i></span>
                    <input type="text" class="form-control" id="sshUser" value="root">
                </div>
            </div>
            <div class="mb-4">
                <label class="form-label">Password</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                    <input type="password" class="form-control" id="sshPass" placeholder="••••••••">
                </div>
            </div>
            <button class="btn btn-connect btn-primary" id="connectBtn">
                <i class="fa-regular fa-paper-plane me-2"></i>Establish SSH session
            </button>
            <div class="small-note">
                <i class="fa-regular fa-circle-info"></i> 
                Your credentials are sent only to your VPS — we never store them.
            </div>
        </div>
    </div>

    <!-- Top bar -->
    <div class="console-topbar">
        <div class="d-flex align-items-center gap-3">
            <div class="vps-badge">
                <i class="fa-solid fa-cube"></i> {{ vps.container_name }}
                <span class="badge bg-dark ms-2">{{ vps.os_version }}</span>
            </div>
            <div class="conn-status" id="connStatus">
                <span class="status-led" id="statusLed"></span>
                <span id="statusText">Disconnected</span>
            </div>
        </div>
        <div class="control-buttons">
            <button class="btn" id="fullscreenBtn" title="Toggle fullscreen (F11)"><i class="fa-regular fa-window-maximize"></i></button>
            <button class="btn" id="reconnectBtn" title="Reconnect"><i class="fa-solid fa-rotate-right"></i></button>
            <button class="btn btn-exit" id="exitBtn" title="Exit console"><i class="fa-regular fa-circle-xmark"></i> Exit</button>
        </div>
    </div>

    <!-- Terminal lives here -->
    <div id="terminal-container"></div>

    <!-- Footer hints -->
    <div class="console-footer">
        <span class="footer-hint"><i class="fa-regular fa-keyboard"></i> Ctrl+C / Ctrl+Z work natively</span>
        <span class="footer-hint"><i class="fa-regular fa-clipboard"></i> Paste: Ctrl+Shift+V / right-click</span>
        <span class="footer-hint"><i class="fa-regular fa-arrow-left"></i> Disconnect does NOT stop your VPS</span>
    </div>

    <!-- scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xterm@5.3.0/lib/xterm.min.js"></script>
    <!-- fit addon for terminal resize -->
    <script src="https://cdn.jsdelivr.net/npm/xterm-addon-fit@0.8.0/lib/xterm-addon-fit.min.js"></script>

    <script>
        (function() {
            // --- Configuration ---
            const vpsId = {{ vps.id }};
            const socket = io(window.location.origin, {
                transports: ['websocket', 'polling'],
                path: '/socket.io'
            });

            // Xterm terminal
            const term = new Terminal({
                cursorBlink: true,
                cursorStyle: 'block',
                fontSize: 14,
                fontFamily: 'JetBrains Mono, Fira Code, monospace',
                theme: {
                    background: '#0c0e12',
                    foreground: '#e6eef9',
                    cursor: '#0dcaf0',
                    selectionBackground: '#2d4c7c',
                    black: '#2e343a',
                    red: '#f07178',
                    green: '#a3d6a3',
                    yellow: '#ffcb6b',
                    blue: '#5fa3e0',
                    magenta: '#d39ad4',
                    cyan: '#7fdbdb',
                    white: '#eef4f9',
                },
                scrollback: 5000,
                tabStopWidth: 4,
            });

            const fitAddon = new FitAddon.FitAddon();
            term.loadAddon(fitAddon);

            // DOM elements
            const overlay = document.getElementById('sshOverlay');
            const statusLed = document.getElementById('statusLed');
            const statusText = document.getElementById('statusText');
            const connectBtn = document.getElementById('connectBtn');
            const sshHost = document.getElementById('sshHost');
            const sshPort = document.getElementById('sshPort');
            const sshUser = document.getElementById('sshUser');
            const sshPass = document.getElementById('sshPass');
            const reconnectBtn = document.getElementById('reconnectBtn');
            const exitBtn = document.getElementById('exitBtn');
            const fullscreenBtn = document.getElementById('fullscreenBtn');
            const terminalContainer = document.getElementById('terminal-container');

            // State
            let connected = false;
            let connecting = false;

            // --- helper: update status UI ---
            function setStatus(state, msg) {
                statusLed.className = 'status-led';
                if (state === 'connected') {
                    statusLed.classList.add('connected');
                    statusText.innerText = msg || 'Connected';
                } else if (state === 'connecting') {
                    statusLed.classList.add('connecting');
                    statusText.innerText = msg || 'Connecting...';
                } else if (state === 'disconnected') {
                    statusLed.classList.add('disconnected');
                    statusText.innerText = msg || 'Disconnected';
                }
            }

            // --- open terminal and attach listeners ---
            function openTerminal() {
                term.open(terminalContainer);
                fitAddon.fit();
                term.focus();
            }

            // Initially open terminal (blank, but UI ready)
            openTerminal();

            // --- socket event handlers ---
            socket.on('connect', () => {
                console.log('Socket.io connected');
                if (!connected && !connecting) {
                    // we show overlay anyway, nothing changes
                }
            });

            socket.on('ssh_connected', (data) => {
                console.log('SSH channel established', data);
                connecting = false;
                connected = true;
                overlay.classList.add('d-none');
                setStatus('connected', `SSH ${data.username}@${data.host}:${data.port}`);
                term.clear();
                term.focus();
            });

            socket.on('ssh_output', (data) => {
                // data is raw string (terminal output)
                term.write(data);
            });

            socket.on('ssh_error', (err) => {
                console.error('SSH error:', err.error);
                connecting = false;
                connected = false;
                setStatus('disconnected', 'Error');
                overlay.classList.remove('d-none');
                term.writeln('\r\n\x1b[1;31m[ SSH ERROR ]\x1b[0m ' + (err.error || 'connection failed'));
                term.writeln('\r\nPlease check credentials and try again.\r\n');
            });

            socket.on('ssh_disconnected', () => {
                console.log('SSH disconnected by server');
                connected = false;
                connecting = false;
                setStatus('disconnected', 'Disconnected');
                overlay.classList.remove('d-none');
                term.writeln('\r\n\x1b[33m[ Session terminated ]\x1b[0m\r\n');
            });

            socket.on('disconnect', () => {
                if (connected) {
                    connected = false;
                    connecting = false;
                    setStatus('disconnected', 'Socket lost');
                    term.writeln('\x1b[1;31m\r\n[!] Connection to panel lost. Reconnecting...\x1b[0m');
                }
            });

            // --- terminal input handling ---
            term.onData(data => {
                if (!connected) return;
                socket.emit('ssh_input', { vps_id: vpsId, input: data });
            });

            // --- connect button logic ---
            function initiateConnection() {
                if (connecting) return;
                const host = sshHost.value.trim();
                const port = parseInt(sshPort.value, 10) || 22;
                const user = sshUser.value.trim() || 'root';
                const pass = sshPass.value.trim();

                if (!host) {
                    alert('Please enter VPS IP or hostname');
                    return;
                }
                if (!pass) {
                    alert('Password is required');
                    return;
                }

                connecting = true;
                connected = false;
                setStatus('connecting', 'SSH handshake');
                overlay.classList.add('d-none');   // hide overlay during attempt (shows status)

                // Clear any previous partial output
                term.clear();
                term.writeln('\x1b[36m[ Connecting to ' + user + '@' + host + ':' + port + ' ... ]\x1b[0m\r\n');

                socket.emit('ssh_connect', {
                    vps_id: vpsId,
                    host: host,
                    port: port,
                    username: user,
                    password: pass
                });
            }

            connectBtn.addEventListener('click', initiateConnection);

            // reconnect button = show overlay and reset status
            reconnectBtn.addEventListener('click', () => {
                if (connected) {
                    socket.emit('ssh_disconnect', { vps_id: vpsId });
                }
                connected = false;
                connecting = false;
                overlay.classList.remove('d-none');
                setStatus('disconnected', 'Ready');
                term.clear();
            });

            // exit console = redirect back to VPS detail
            exitBtn.addEventListener('click', () => {
                if (connected) {
                    socket.emit('ssh_disconnect', { vps_id: vpsId });
                }
                window.location.href = `/vps/${vpsId}`;
            });

            // fullscreen toggle
            fullscreenBtn.addEventListener('click', () => {
                if (!document.fullscreenElement) {
                    document.documentElement.requestFullscreen();
                } else {
                    if (document.exitFullscreen) {
                        document.exitFullscreen();
                    }
                }
            });

            // resize terminal on window resize
            window.addEventListener('resize', () => {
                if (term && fitAddon) {
                    fitAddon.fit();
                    if (connected) {
                        // send new terminal size to server (pty resize)
                        const dims = fitAddon.proposeDimensions();
                        if (dims) {
                            socket.emit('ssh_resize', {
                                vps_id: vpsId,
                                cols: dims.cols,
                                rows: dims.rows
                            });
                        }
                    }
                }
            });

            // handle F11 for fullscreen (prevent default)
            document.addEventListener('keydown', (e) => {
                if (e.key === 'F11') {
                    e.preventDefault();
                    fullscreenBtn.click();
                }
                // Ctrl+Shift+V paste (simple)
                if (e.ctrlKey && e.shiftKey && e.key === 'V') {
                    e.preventDefault();
                    navigator.clipboard.readText().then(text => {
                        if (connected && text) {
                            socket.emit('ssh_input', { vps_id: vpsId, input: text });
                        }
                    }).catch(() => {});
                }
            });

            // prevent back/forward mouse buttons
            window.addEventListener('popstate', (e) => {
                if (connected) {
                    e.preventDefault();
                }
            });

            // if user hits enter on password field
            sshPass.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    connectBtn.click();
                }
            });

            // prefill host if vps_ip was passed from backend (e.g. {{ vps_ip|safe }})
            // but we already set value via template variable
            // final fallback: if vps has ip_address in db, template already injected

            // on disconnect while overlay visible, ensure status led
            setStatus('disconnected', 'Awaiting connection');

            // attempt to prefill with vps_ip, but if empty, maybe use node's display ip?
            // we already did value="{{ vps_ip or '' }}" in input, fine.

            // optional: reconnect if socket reconnects while overlay not active? we keep overlay as gatekeeper.

            // handle ctrl+c properly in terminal (just send)
            // no extra actions needed

            // additional: close ssh if user navigates away
            window.addEventListener('beforeunload', () => {
                if (connected) {
                    socket.emit('ssh_disconnect', { vps_id: vpsId });
                }
            });

            // Manual focus to host input if overlay visible
            if (!overlay.classList.contains('d-none')) {
                sshHost.focus();
            }

            // Prevent accidental touch events bubbling
        })();
    </script>

    <!-- In case xterm fit addon not fully loaded, retry fit after 200ms -->
    <script>
        (function secondaryFit() {
            setTimeout(() => {
                if (window.fitAddon) {
                    try { window.fitAddon.fit(); } catch(e) {}
                } else {
                    // try to get from global scope if available
                    if (typeof FitAddon !== 'undefined' && term) {
                        try { 
                            const fit = new FitAddon.FitAddon();
                            term.loadAddon(fit);
                            fit.fit();
                            window.fitAddon = fit;
                        } catch (e) {}
                    }
                }
            }, 200);
        })();
    </script>
</body>
</html>
