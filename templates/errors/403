<!-- templates/errors/403.html -->
{% extends "base.html" %}

{% block page_icon %}fas fa-lock{% endblock %}
{% block page_title %}403 - Forbidden{% endblock %}

{% block content %}
<div style="min-height: 60vh; display: flex; align-items: center; justify-content: center;">
    <div class="card" style="max-width: 500px; width: 100%; text-align: center;">
        <div class="card-body" style="padding: 3rem;">
            <i class="fas fa-lock fa-5x text-danger" style="margin-bottom: 1.5rem;"></i>
            <h1 style="font-size: 4rem; font-weight: 800; margin-bottom: 0.5rem;">403</h1>
            <h2 style="margin-bottom: 1rem;">Access Forbidden</h2>
            <p class="text-muted" style="margin-bottom: 2rem;">
                You don't have permission to access this resource.
            </p>
            <div style="display: flex; gap: 1rem; justify-content: center;">
                <a href="javascript:history.back()" class="btn btn-outline">
                    <i class="fas fa-arrow-left"></i> Go Back
                </a>
                <a href="{{ url_for('dashboard') }}" class="btn btn-primary">
                    <i class="fas fa-home"></i> Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
